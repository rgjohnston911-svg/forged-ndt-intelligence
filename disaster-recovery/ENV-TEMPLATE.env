###############################################################
# 4D NDT INTELLIGENCE PLATFORM — ENVIRONMENT VARIABLES
# Owner: Richard Johnston
# Last Updated: 2026-05-01
#
# INSTRUCTIONS:
# 1. Copy this file and fill in your actual values
# 2. NEVER commit the filled version to git
# 3. Add the filled version to Netlify: Site Settings → Environment Variables
# 4. For local development, save as .env in project root
#
# SECURITY: This template contains NO actual secrets.
# Store your filled copy in a password manager (1Password, Bitwarden, etc.)
###############################################################

#--------------------------------------------------------------
# SUPABASE — Database & Auth
# Get these from: https://supabase.com/dashboard → Project → Settings → API
#--------------------------------------------------------------

# Project URL (public, safe to expose in frontend)
SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key — public, used by frontend (Supabase RLS enforces security)
SUPABASE_ANON_KEY=eyJ...your-anon-key

# Service Role Key — SECRET, server-side only, bypasses RLS
# Used by Netlify functions to read/write without auth restrictions
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

#--------------------------------------------------------------
# FRONTEND — Vite build-time variables
# These are embedded in the built JS bundle (public by design)
# Prefix with VITE_ so Vite includes them
#--------------------------------------------------------------

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

#--------------------------------------------------------------
# AI MODEL KEYS — SECRET, server-side only
# Used by tri-model reasoning, superbrain synthesis, report generation
#--------------------------------------------------------------

# OpenAI — Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-openai-key

# Anthropic — Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key

#--------------------------------------------------------------
# NETLIFY — Auto-provided (DO NOT set manually)
# These are injected by Netlify at build/runtime automatically
#--------------------------------------------------------------

# URL              → Production URL (e.g., https://4dndt.com)
# DEPLOY_URL       → Unique URL for this specific deploy
# DEPLOY_PRIME_URL → URL for the branch deploy

###############################################################
# BACKUP CHECKLIST — Where to find each value if you lose access:
#
# SUPABASE_URL:               Supabase Dashboard → Settings → API
# SUPABASE_ANON_KEY:          Supabase Dashboard → Settings → API → anon public
# SUPABASE_SERVICE_ROLE_KEY:  Supabase Dashboard → Settings → API → service_role
# OPENAI_API_KEY:             OpenAI Platform → API Keys
# ANTHROPIC_API_KEY:          Anthropic Console → API Keys
# VITE_SUPABASE_URL:          Same as SUPABASE_URL
# VITE_SUPABASE_ANON_KEY:     Same as SUPABASE_ANON_KEY
#
# RECOMMENDATION: Store all values in a password manager entry
# titled "4D NDT Platform — Production Secrets"
###############################################################
